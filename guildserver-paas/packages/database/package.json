{
  "name": "@guildserver/database",
  "version": "1.0.0",
  "description": "GuildServer database schemas and migrations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate:pg",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed.ts",
    "db:seed-plans": "tsx src/seed-plans.ts",
    "db:backfill-subscriptions": "tsx src/backfill-subscriptions.ts"
  },
  "dependencies": {
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.29.1",
    "postgres": "^3.4.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "drizzle-kit": "^0.20.6",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  }
}