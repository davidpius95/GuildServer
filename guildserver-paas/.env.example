# Database Configuration
DATABASE_URL="postgresql://guildserver:password@localhost:5432/guildserver"
DATABASE_DIRECT_URL="postgresql://guildserver:password@localhost:5432/guildserver"

# Redis Configuration
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# Application Configuration
NODE_ENV="development"
APP_URL="http://localhost:3000"
API_URL="http://localhost:3001"

# Authentication
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# JWT Configuration
JWT_SECRET="your-jwt-secret-here"
JWT_EXPIRES_IN="7d"

# Email Configuration (Optional)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@guildserver.com"

# Storage Configuration
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# Docker Configuration
DOCKER_HOST="unix:///var/run/docker.sock"
DOCKER_CERT_PATH=""
DOCKER_TLS_VERIFY=""

# Kubernetes Configuration
KUBECONFIG_PATH=""
KUBERNETES_NAMESPACE="guildserver"

# Monitoring Configuration
PROMETHEUS_URL=""
GRAFANA_URL=""
JAEGER_URL=""

# Enterprise Features
ENTERPRISE_MODE="false"
SAML_ENABLED="false"
OIDC_ENABLED="false"
COMPLIANCE_ENABLED="false"

# SAML Configuration (Enterprise)
SAML_ENTITY_ID=""
SAML_SSO_URL=""
SAML_CERT=""

# OIDC Configuration (Enterprise)
OIDC_ISSUER=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""

# Compliance Configuration (Enterprise)
SOC2_ENABLED="false"
HIPAA_ENABLED="false"
PCI_ENABLED="false"

# Security Configuration
VAULT_URL=""
VAULT_TOKEN=""
SECURITY_SCANNING_ENABLED="false"

# Cost Management (Enterprise)
COST_TRACKING_ENABLED="false"
AWS_COST_EXPLORER_KEY=""
AZURE_COST_MANAGEMENT_KEY=""
GCP_BILLING_KEY=""

# Workflow Management (Enterprise)
WORKFLOW_ENGINE_ENABLED="false"
APPROVAL_WORKFLOWS_ENABLED="false"

# Multi-Region Configuration (Enterprise)
MULTI_REGION_ENABLED="false"
PRIMARY_REGION="us-east-1"
SECONDARY_REGIONS="us-west-2,eu-west-1"

# Development Configuration
DEBUG="false"
LOG_LEVEL="info"
SENTRY_DSN=""