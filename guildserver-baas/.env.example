# ── Shared with GuildServer PaaS ──────────────────────────────────────────────
# Point at the same Postgres instance as guildserver-paas
DATABASE_URL=postgres://guildserver:password123@localhost:5433/guildserver
# Must match guildserver-paas JWT_SECRET exactly (token hand-off between apps)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ── BaaS API ──────────────────────────────────────────────────────────────────
BAAS_API_PORT=4001
BAAS_WEB_URL=http://localhost:3001
# Base domain for auto-generated project URLs  (<slug>.baas.<domain>)
BAAS_BASE_DOMAIN=baas.localhost
BAAS_FALLBACK_DOMAIN=baas.guildserver.com

# ── Redis (BullMQ job queues) ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Cloudflare for SaaS (custom domain support) ───────────────────────────────
CF_ZONE_ID=
CF_API_TOKEN=

# ── SSH (scheduler reaches compute nodes via SSH) ─────────────────────────────
SSH_AUTH_SOCK=/tmp/ssh-agent.sock

# ── SMTP (forwarded to GoTrue inside each provisioned stack) ──────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── PaaS back-link (shown in BaaS web "switch product" link) ─────────────────
NEXT_PUBLIC_PAAS_WEB_URL=http://localhost:3000
