{
  "name": "guildserver-baas",
  "version": "1.0.0",
  "description": "GuildServer Backend-as-a-Service — self-hosted Supabase Cloud on decentralised infrastructure",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "turbo run db:migrate",
    "db:generate": "turbo run db:generate"
  },
  "devDependencies": {
    "turbo": "^1.13.3",
    "typescript": "^5.4.5",
    "prettier": "^3.2.5"
  },
  "engines": { "node": ">=20", "pnpm": ">=9" },
  "packageManager": "pnpm@9.1.0"
}
